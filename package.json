{
  "name": "crontick",
  "version": "0.0.0",
  "description": "A standalone cron daemon, CLI, and MCP server for local scheduled jobs.",
  "type": "module",
  "license": "MIT",
  "private": false,
  "author": "crontick contributors",
  "homepage": "https://github.com/crontick/crontick",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/crontick/crontick.git"
  },
  "bugs": {
    "url": "https://github.com/crontick/crontick/issues"
  },
  "engines": {
    "node": ">=22.5"
  },
  "bin": {
    "crontick": "./dist/cli/index.js",
    "crontick-daemon": "./dist/daemon/index.js",
    "crontick-mcp": "./dist/mcp/index.js"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "plugin/**",
    "src/skill/SKILL.md",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup && node scripts/fix-node-sqlite.mjs",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "release": "changeset publish",
    "prepublishOnly": "npm run build && npm test"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.17.0",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "commander": "^12.1.0",
    "croner": "^9.0.0",
    "env-paths": "^3.0.0",
    "pino": "^9.4.0",
    "zod": "^4.4.3",
    "zod-to-json-schema": "^3.25.2"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.9",
    "@eslint/js": "^9.12.0",
    "@types/node": "^26.1.1",
    "@vitest/coverage-v8": "^2.1.2",
    "eslint": "^9.12.0",
    "fast-check": "^4.9.0",
    "prettier": "^3.3.3",
    "tsup": "^8.3.0",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.8.1",
    "vitest": "^2.1.2"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
